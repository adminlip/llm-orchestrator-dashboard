[Unit]
Description=LLM Orchestrator Dashboard
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/llm-orchestrator-dashboard
EnvironmentFile=-/opt/llm-orchestrator-dashboard/.env
ExecStart=/opt/llm-orchestrator-dashboard/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
