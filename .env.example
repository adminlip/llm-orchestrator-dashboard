# LLM Orchestrator Dashboard environment

# OpenAI-compatible provider key.
# This can be Mimo, OpenAI, OpenRouter, or any service compatible with /v1/chat/completions.
OPENAI_API_KEY=your-openai-compatible-key

# Optional platform keys.
CODECLUE_API_KEY=your-codeclue-key
OPENCLUE_API_KEY=your-openclue-key

# Optional Hermes gateway endpoint.
HERMES_API_URL=http://127.0.0.1:8642

# Optional server options used by start.sh. On Windows edit start.bat directly if needed.
APP_HOST=0.0.0.0
APP_PORT=8000
